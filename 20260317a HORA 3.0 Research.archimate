    <element xsi:type="archimate:Value" name="Public funds" id="id-48e236cfb91e40188983672e45c55049"/>
  </folder>
  <folder name="Implementation &amp; Migration" id="id-7a1feb37afb74d17abc6c0b8117c67fd" type="implementation_migration"/>
  <folder name="Other" id="id-4ab02ff6be1a41d382f6720dfd391f34" type="other">
    <element xsi:type="archimate:Grouping" name="Value propostion" id="id-e8e2d7994ff940f98a2324e61d9e4051"/>
