    <element xsi:type="archimate:BusinessProcess" name="Aanvragen onderzoeksinfrastructuur en -middelen" id="id-a5599a552bf94f50bd003105760371e4">
      <documentation>Zorgen dat faciliteiten, tooling en middelen beschikbaar en toegankelijk zijn voor de uitvoering.</documentation>
      <property/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Inrichten en onderhouden onderzoeksdata-werkomgeving (RDM)" id="id-f6760fe0768540a4b54602021f0fa95d">
      <documentation>Inrichten en beheren van de werkomgeving voor veilige opslag, verwerking en samenwerking op onderzoeksdata.</documentation>
      <property/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Uitvoeren juridische, ethische en privacy toetsing" id="id-18c8c91176ff4d5490b0c42f6b68b7ce">
      <documentation>Borgen dat onderzoek voldoet aan wet- en regelgeving en ethische normen vóór uitvoering en bij wijzigingen.</documentation>
      <property/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Toetsen onderzoeksintegriteit, informatiebeveiliging en kwaliteitszorg" id="id-bfb0965ea24940389f78dc0d81ed3613">
      <documentation>Waarborgen van integriteit, kwaliteit en beveiliging tijdens voorbereiding en uitvoering van onderzoek.</documentation>
      <property/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Werven en contracteren onderzoeksteam en onderzoekspopulatie/ materiaal" id="id-9f6b85cea1cf48ebae1a6244072ff48a">
      <documentation>Realiseren van benodigde capaciteit en toegang tot deelnemers, objecten en materiaal conform protocol.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Ontwikkelen methodologie en onderzoeksinstrumenten" id="id-12ee3cf6bb504a4999f88433f8b1d920">
      <documentation>Ontwerpen, testen en vastleggen van methode, meetinstrumenten en procedures voor dataverzameling.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Verzamelen onderzoeksdata en -materiaal" id="id-5563cca2b2cf44028820ccd4035c109c">
      <documentation>Uitvoeren van dataverzameling volgens protocol en vastleggen van datakwaliteit en herleidbaarheid.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Analyseren onderzoeksdata en valideren bevindingen" id="id-cacc702b7bd3474d9623b4bb70b27a1e">
      <documentation>Analyseren van data en toetsen van bevindingen op robuustheid, reproduceerbaarheid en relevantie.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Opstellen en beheren IP-contracten en afspraken" id="id-94c055b520ba4aeba5cb1247e0033d46">
      <documentation>Juridisch vastleggen en beheren van afspraken over samenwerking, financiele afwikkeling
 en data t.a.v. intellectueel eigendom.</documentation>
      <property/>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Publiceren en dissemineren onderzoeksresultaten" id="id-95a8ee0bcac04a11874aba0008fd9516">
      <documentation>Delen van resultaten via publicaties en communicatiekanalen, inclusief peer review en open access waar passend.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Beoordelen valorisatiepotentieel en beheren IPR" id="id-391e4fde502c4f34a0b534562c7b81a8">
      <documentation>Beoordelen van benuttingskansen en organiseren van passende bescherming en beheer van intellectueel eigendom.</documentation>
    </element>
    <element xsi:type="archimate:BusinessProcess" name="Realiseren kennisbenutting en commercialisatie" id="id-22a2d984cb444dd39391e21694d36dd7">
      <documentation>Toepassen van resultaten in praktijk en markt via kennisoverdracht, co-creatie, licenties of start-ups.</documentation>
    </element>
